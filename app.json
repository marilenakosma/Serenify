{
  "expo": {
    "name": "Serenify",
    "slug": "Serenify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/leaf-green.png",
    "scheme": "serenify",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        //"backgroundColor": "#fcf9f4",
        "foregroundImage": "./assets/images/adaptive-icon.png"
       // "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Serenify"
    },
    "web": {
      "output": "static"
     // "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
     /* [
        
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ] */
      "expo-font",
      "expo-web-browser",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
