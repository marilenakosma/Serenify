{
  "expo": {
    "name": "Serenify",
    "slug": "Serenify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/leaf-green.png",
    "scheme": "serenify",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Serenify"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-localization",
      "expo-audio",
      "expo-asset",
     // [
        //"expo-splash-screen",
       // {
       //   "image": "./assets/images/splash-icon.png",
       //   "resizeMode": "contain",
       //   "backgroundColor": "#dbe7d3"
      //  }
     // ],
      "react-native-bootsplash"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
